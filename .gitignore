# Node / TypeScript (Executor output)
node_modules/
dist/
build/
*.tsbuildinfo
.npm/
.pnpm-store/

# Python (only validators)
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Env / secrets — NEVER commit these
.env
.env.*
!.env.example

# OS / editors
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Local artifacts
*.log
*.sqlite
*.db
data/
tmp/
.cache/

# Test coverage / reports
coverage/
.nyc_output/
htmlcov/
.pytest_cache/

# Misc
.devin/

# Sisyphus orchestrator runtime state (run-continuation cache, dump
# placeholders that the executor creates as rollback safety-nets but
# never actually populates, etc.) — local-only, never committed.
.sisyphus/
backups/

# Operator-edited config files (live in the kbju_config named volume, not git)
config/allowlist.json
config/llm.json

# Incident bundles (diag-bundle.sh output; operators attach to GitHub issues)
/incidents/
