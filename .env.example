# KBJU Coach — required environment variables
# Copy to .env and fill in real values. Never commit real secrets.
# Reference: ARCH-001@0.7.0 §9.1

TELEGRAM_BOT_TOKEN=
TELEGRAM_PILOT_USER_IDS=
DATABASE_URL=
POSTGRES_PASSWORD=
USDA_FDC_API_KEY=
PERSONA_PATH=
PO_ALERT_CHAT_ID=
MONTHLY_SPEND_CEILING_USD=10
AUDIT_DB_URL=

# --- LLM provider keys (ADR-022@0.1.0, ADR-024@0.1.0) ---
# New canonical names (preferred). The model registry (config/llm.json) references
# these env-var names in the providers[*].api_key_env field.
LLM_OMNIROUTE_BASE_URL=
LLM_OMNIROUTE_API_KEY=
LLM_FIREWORKS_API_KEY=

# DEPRECATED — removal target v0.8.0. Still read as fallback when the
# LLM_* equivalents are unset, with a one-shot deprecation warning.
# Do NOT rely on these for new deployments.
OMNIROUTE_BASE_URL=
OMNIROUTE_API_KEY=
FIREWORKS_API_KEY=

# --- TLS termination (ADR-020@0.1.1) ---
# KBJU_PUBLIC_DOMAIN: the public DNS name for the Telegram webhook (e.g. bot.example.com).
# Required for Caddy + Let's Encrypt (default path). Ignored in cloudflare-tunnel mode.
KBJU_PUBLIC_DOMAIN=
# CLOUDFLARED_TUNNEL_TOKEN: the tunnel token from the Cloudflare dashboard.
# Only needed when INSTALL_TLS_MODE=cloudflare-tunnel.
CLOUDFLARED_TUNNEL_TOKEN=
# INSTALL_TLS_MODE: "caddy" (default) or "cloudflare-tunnel".
# Selects the TLS termination mode for install.sh.
INSTALL_TLS_MODE=caddy
